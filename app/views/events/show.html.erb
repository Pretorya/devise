<!DOCTYPE html>
<html>
  <head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/flatly/bootstrap.min.css" rel="stylesheet">
  </head>
<body>
<div class="container my-4">
  <h1><%= @event.title %></h1>
  <p><%= @event.description %></p>
  <p><strong>Début :</strong> <%= @event.start_date.strftime("%d %b %Y %H:%M") %></p>
  <p><strong>Durée :</strong> <%= @event.duration %> minutes</p>
  <p><strong>Lieu :</strong> <%= @event.location %></p>
  <p><strong>Prix :</strong> <%= @event.price %>€</p>
  <p><strong>Créateur :</strong> <%= @event.user.email %></p>
</div>

<% if user_signed_in? %>

  <% if current_user == @event.user %>
    <%= link_to "Mon espace événement", event_atendances_path(@event) %>

  <% elsif @event.users.include?(current_user) %>
    <p>Tu participes déjà à cet événement ✅</p>

  <% else %>
    <%= link_to "Rejoindre l’événement", new_event_atendance_path(@event), class: "btn btn-primary" %>
  <% end %>

<% else %>
  <%= link_to "Connecte-toi pour participer", new_user_session_path %>
<% end %>

</body>

</html>
